# notes-mcp 环境变量示例
# 用法:cp .env.example .env,再按本地情况改 NOTES_DIR 等
# 详见 docs/配置.md §4 —— 改配置项必须同步该文件(单一信息源)

# ===== 笔记数据 =====
# 笔记目录(支持多个,分号 ; 分隔;笔记分散在多处也行)
NOTES_DIR=d:/Learn/AI/笔记

# ===== ollama(生成 + 嵌入)=====
# 用 127.0.0.1 不用 localhost,避 Windows IPv6 解析问题
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=qwen3:8b
OLLAMA_API_KEY=ollama
EMBED_MODEL=bge-m3

# ===== 检索 / 切块 =====
TOP_K=5
CHUNK_SIZE=300
OVERLAP=50

# ===== 存储 =====
CHROMA_PATH=./data/chroma
SQLITE_PATH=./data/index_state.db

# ===== notes-mcp server(HTTP transport,供 Web 后端 / 外部 client 连)=====
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8765

# ===== Web 后端(FastAPI)=====
WEB_BACKEND_HOST=0.0.0.0
WEB_BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173        # CORS 白名单(Vite dev 默认端口)

# ===== 日志 =====
LOG_LEVEL=INFO
